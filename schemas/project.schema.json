{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://builderhub.azure.com/schemas/project.json",
  "title": "Azure Builder Hub Project Manifest",
  "description": "Defines the project metadata for an Azure Builder playground project. This file lives in the designer's sandbox repo and is read by the GitHub Action that publishes to the hub.",
  "type": "object",
  "required": ["name", "author", "pages"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 100,
      "description": "Human-readable project name"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Brief project description"
    },
    "author": {
      "type": "object",
      "required": ["name", "id"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Author display name"
        },
        "id": {
          "type": "string",
          "description": "Author email or Entra ID identifier"
        }
      },
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "maxLength": 50 },
      "maxItems": 10,
      "uniqueItems": true,
      "description": "Searchable tags (e.g., dashboard, monitoring, AI)"
    },
    "azureServices": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "description": "Azure services referenced in this project (e.g., Azure Monitor, Azure AI Services)"
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "component", "route"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Page display name"
          },
          "schema": {
            "type": "string",
            "description": "Relative path to the page schema JSON file"
          },
          "component": {
            "type": "string",
            "description": "Relative path to the page component (.tsx)"
          },
          "route": {
            "type": "string",
            "pattern": "^/",
            "description": "URL route for this page (must start with /)"
          }
        },
        "additionalProperties": false
      },
      "description": "List of pages in the project"
    },
    "thumbnail": {
      "type": "string",
      "description": "Relative path to thumbnail image (PNG/JPEG, recommended 1200x630)"
    },
    "layout": {
      "type": "string",
      "enum": ["full-width", "side-panel"],
      "default": "full-width",
      "description": "Primary layout type of the project"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Current version number (auto-incremented by the hub)"
    },
    "published": {
      "type": "boolean",
      "default": false,
      "description": "Whether the project is published to the community gallery"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    }
  },
  "additionalProperties": false
}
